<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="MenuStyle" parent="Widget.AppCompat.Light.PopupMenu.Overflow">
        <item name="android:popupBackground">@color/colorMenuBackground</item>
        <item name="android:textSize">@dimen/textSize</item>
        <item name="android:textColorPrimary">@color/colorText</item>
        <!--把该属性改为false即可使menu位置位于toolbar之下-->
        <item name="overlapAnchor">false</item>
    </style>

    <!-- Custom title text appearance -->
    <style name="TitleAppearance" parent="@style/TextAppearance.AppCompat.Title">
        <item name="android:textColor">@color/colorTitle</item>
        <item name="android:textSize">@dimen/titleSize</item>
    </style>
    <style name="TitleProfileAppearance" parent="@style/Widget.AppCompat.ActionBar.TabText">
        <item name="android:textColor">@color/colorToolbarTitle</item>
        <item name="android:textSize">@dimen/titleSize</item>
    </style>

    <!-- Custom text appearance -->
    <style name="TextAppearance" parent="@style/Widget.AppCompat.ActionBar.TabText">
        <item name="android:textColor">@color/colorText</item>
        <item name="android:textSize">@dimen/textSize</item>
    </style>
    <style name="TextToolbarAppearance" parent="@style/Widget.AppCompat.ActionBar.TabText">
        <item name="android:textColor">@color/colorToolbarTitle</item>
        <item name="android:textSize">@dimen/hintSize</item>
    </style>
    <style name="TextProfileAppearance" parent="@style/Widget.AppCompat.ActionBar.TabText">
        <item name="android:textColor">@color/colorToolbarTitle</item>
        <item name="android:textSize">@dimen/textSize</item>
    </style>
    <style name="TextEditProfileAppearance" parent="@style/Widget.AppCompat.ActionBar.TabText">
        <item name="android:textColor">@color/colorTitle</item>
        <item name="android:textSize">@dimen/textSize</item>
    </style>

    <!-- Custom tip appearance -->
    <style name="TipBlackAppearance" parent="@style/Widget.AppCompat.ActionBar.TabText">
        <item name="android:textColor">@color/colorText</item>
        <item name="android:textSize">@dimen/hintSize</item>
    </style>
    <style name="TipRedAppearance" parent="@style/Widget.AppCompat.ActionBar.TabText">
        <item name="android:textColor">@color/colorWarning</item>
        <item name="android:textSize">@dimen/hintSize</item>
    </style>
    <style name="TipProfileAppearance" parent="@style/Widget.AppCompat.ActionBar.TabText">
        <item name="android:textColor">@color/colorToolbarTitle</item>
        <item name="android:textSize">@dimen/hintSize</item>
    </style>

    <!-- Custom activity appearance -->
    <style name="CollapsingToolbarActivityTheme" parent="AppTheme">
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

    <!--dialog appearance-->
    <style name="DialogStyle">
        <!--对话框背景 -->
        <item name="android:windowBackground">@android:color/transparent</item>
        <!--边框 -->
        <item name="android:windowFrame">@null</item>
        <!--没有标题 -->
        <item name="android:windowNoTitle">true</item>
        <!-- 是否浮现在Activity之上 -->
        <item name="android:windowIsFloating">true</item>
        <!--背景透明 -->
        <item name="android:windowIsTranslucent">false</item>
        <!-- 是否有覆盖 -->
        <item name="android:windowContentOverlay">@null</item>
        <!--背景变暗-->
        <item name="android:backgroundDimEnabled">true</item>
    </style>

</resources>
