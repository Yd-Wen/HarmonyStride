<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/dimen1"
    android:padding="@dimen/dimen5"
    app:cardCornerRadius="4dp"
    app:cardElevation="5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingVertical="@dimen/dimen5">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/dimen10">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/civ_avatar"
                android:layout_width="@dimen/dimen50"
                android:layout_height="@dimen/dimen50"
                app:civ_border_color="@color/colorCircleImageBorder"
                android:layout_gravity="center_vertical"
                android:src="@drawable/default_avatar"
                android:foreground="@drawable/avatar_stroke_default"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_user_nickname"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="@dimen/dimen10"
                    android:paddingTop="@dimen/dimen5"
                    android:textAppearance="@style/TextAppearance" />

                <TextView
                    android:id="@+id/tv_comment_datetime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="@dimen/dimen10"
                    android:textAppearance="@style/TipBlackAppearance" />

            </LinearLayout>

            <ImageView
                android:id="@+id/iv_more"
                android:layout_width="@dimen/dimen30"
                android:layout_height="match_parent"
                android:src="@drawable/more"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tv_comment_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dimen50"
            android:paddingHorizontal="@dimen/dimen10"
            android:textAppearance="@style/TextAppearance"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>

