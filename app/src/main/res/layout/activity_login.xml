<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".activity.LoginActivity">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/tool_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/actionBarSize"
        android:background="@color/colorPrimary"
        app:popupTheme="@style/MenuStyle"
        app:titleTextAppearance="@style/TitleAppearance"
        app:title="@string/login"/>

    <de.hdodenhof.circleimageview.CircleImageView
        android:layout_width="@dimen/dimen200"
        android:layout_height="@dimen/dimen200"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/dimen10"
        android:src="@drawable/icon"
        app:civ_border_color="@color/colorCircleImageBorder"
        app:civ_border_width="@dimen/dimen2"
        app:civ_circle_background_color="@color/colorCircleImageBackground" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen5"
        android:layout_marginHorizontal="@dimen/dimen30"
        app:cardCornerRadius="@dimen/dimen30"
        app:cardElevation="@dimen/dimen30"
        app:cardBackgroundColor="@color/colorFormBackground">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/dimen20"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/dimen50"
                android:orientation="horizontal"
                android:paddingVertical="@dimen/dimen5">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:text="@string/account"
                    android:textAppearance="@style/TitleAppearance" />

                <EditText
                    android:id="@+id/et_account"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="3"
                    android:autofillHints="username"
                    android:hint="@string/account_hint"
                    android:inputType="number"
                    android:maxEms="11"
                    android:textAppearance="@style/TextAppearance"
                    android:textColorHint="@color/colorHint"
                    android:background="@drawable/shape_edit_text"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/dimen50"
                android:orientation="horizontal"
                android:paddingVertical="@dimen/dimen5">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:text="@string/password"
                    android:textAppearance="@style/TitleAppearance" />

                <EditText
                    android:id="@+id/et_password"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="3"
                    android:autofillHints="password"
                    android:hint="@string/password_hint"
                    android:inputType="textPassword"
                    android:maxEms="12"
                    android:minEms="6"
                    android:textAppearance="@style/TextAppearance"
                    android:textColorHint="@color/colorHint"
                    android:background="@drawable/shape_edit_text"/>

            </LinearLayout>

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="@dimen/dimen5">

                <Button
                    android:id="@+id/btn_register"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="@dimen/dimen5"
                    android:layout_gravity="center_vertical"
                    android:textAppearance="@style/TextAppearance"
                    android:text="@string/register"
                    android:gravity="center"
                    android:background="@drawable/selector_shape_button_orange"
                    style="?android:attr/buttonBarButtonStyle" />

                <Button
                    android:id="@+id/btn_login"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:layout_gravity="center_vertical"
                    android:textAppearance="@style/TitleAppearance"
                    android:text="@string/login"
                    android:gravity="center"
                    android:background="@drawable/selector_shape_button_blue"
                    style="?android:attr/buttonBarButtonStyle" />

            </LinearLayout>

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="@dimen/dimen5">

                <CheckBox
                    android:id="@+id/cb_password_remember"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:textAppearance="@style/TipBlackAppearance"
                    android:text="@string/password_remember" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"/>

                <TextView
                    android:id="@+id/tv_password_forget"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="end|center_vertical"
                    android:textAppearance="@style/TipRedAppearance"
                    android:text="@string/password_forget"/>

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>