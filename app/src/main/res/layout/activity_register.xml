<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/shape_app_background"
    tools:context=".activity.RegisterActivity">

  <androidx.cardview.widget.CardView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_gravity="center"
      android:layout_marginTop="@dimen/dimen5"
      android:layout_marginHorizontal="@dimen/dimen30"
      app:cardCornerRadius="@dimen/dimen30"
      app:cardElevation="@dimen/dimen30"
      app:cardBackgroundColor="@color/colorFormBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/dimen20"
        android:orientation="vertical">
      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="horizontal"
          android:layout_marginBottom="@dimen/dimen30">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/AppTitleAppearance"
            android:textColor="@color/colorPrimaryDark"
            android:text="@string/register"/>
        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"/>
        <ImageView
            android:id="@+id/iv_close"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:src="@drawable/close"/>
      </LinearLayout>

        <EditText
            android:id="@+id/et_account"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen50"
            android:layout_marginVertical="@dimen/dimen10"
            android:autofillHints="username"
            android:hint="@string/account_hint"
            android:inputType="number"
            android:maxEms="11"
            android:textAppearance="@style/TextAppearance"
            android:textColorHint="@color/colorHint"
            android:background="@drawable/shape_edit_text"
            android:drawableStart="@drawable/user_account"
            android:drawableTint="@color/colorPrimaryDark"
            android:drawablePadding="@dimen/dimen10"/>

      <EditText
          android:id="@+id/et_password"
          android:layout_width="match_parent"
          android:layout_height="@dimen/dimen50"
          android:layout_marginVertical="@dimen/dimen10"
          android:autofillHints="password"
          android:hint="@string/password_hint"
          android:inputType="textPassword"
          android:maxEms="12"
          android:minEms="6"
          android:textAppearance="@style/TextAppearance"
          android:textColorHint="@color/colorHint"
          android:background="@drawable/shape_edit_text"
          android:drawableStart="@drawable/user_pwd"
          android:drawableTint="@color/colorPrimaryDark"
          android:drawablePadding="@dimen/dimen10"/>

      <EditText
          android:id="@+id/et_verification_code"
          android:layout_width="match_parent"
          android:layout_height="@dimen/dimen50"
          android:layout_marginVertical="@dimen/dimen10"
          android:autofillHints="username"
          android:hint="@string/verification_code_hint"
          android:inputType="number"
          android:maxEms="6"
          android:textAppearance="@style/TextAppearance"
          android:textColorHint="@color/colorHint"
          android:background="@drawable/shape_edit_text"
          android:drawableStart="@drawable/verification"
          android:drawableTint="@color/colorPrimaryDark"
          android:drawablePadding="@dimen/dimen10"/>

      <LinearLayout
          android:orientation="horizontal"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:paddingVertical="@dimen/dimen5">

        <Button
            android:id="@+id/btn_verification_code_get"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:layout_margin="@dimen/dimen5"
            android:layout_gravity="center_vertical"
            android:textAppearance="@style/TextAppearance"
            android:text="@string/verification_code_get"
            android:gravity="center"
            android:background="@drawable/selector_shape_button_orange"
            style="?android:attr/buttonBarButtonStyle" />

        <Button
            android:id="@+id/btn_register"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="3"
            android:layout_gravity="center_vertical"
            android:textAppearance="@style/TitleAppearance"
            android:text="@string/register"
            android:gravity="center"
            android:background="@drawable/selector_shape_button_blue"
            style="?android:attr/buttonBarButtonStyle" />

      </LinearLayout>

      <CheckBox
          android:id="@+id/cb_privacy_agree"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="@string/privacy_agree"
          android:textAppearance="@style/TipBlackAppearance" />

    </LinearLayout>

  </androidx.cardview.widget.CardView>

  <LinearLayout
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_gravity="bottom|center"
      android:layout_marginBottom="@dimen/dimen20"
      android:orientation="horizontal">
    <de.hdodenhof.circleimageview.CircleImageView
        android:layout_width="@dimen/dimen50"
        android:layout_height="@dimen/dimen50"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/dimen10"
        android:src="@drawable/icon"
        app:civ_border_color="@color/colorCircleImageBorder"
        app:civ_border_width="@dimen/dimen2" />
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="@dimen/dimen50"
        android:gravity="center"
        android:paddingHorizontal="@dimen/dimen10"
        android:textColor="@color/colorWhite"
        android:text="@string/harmony_stride"
        android:textSize="@dimen/titleSize" />

  </LinearLayout>

</FrameLayout>